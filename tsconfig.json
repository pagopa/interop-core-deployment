{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2022",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["scripts/__tests__/**", "vitest.config.ts"]
}
